<Window x:Class="MediaConfigTool.Views.SlideshowWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Slideshow"
        Width="860" Height="680"
        Background="#1E1E1E"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <DockPanel Background="#1E1E1E">

        <!-- Top bar -->
        <Border DockPanel.Dock="Top"
                Background="#2A2A2A"
                BorderBrush="#444444"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <DockPanel>
                <Button Content="✕"
                        DockPanel.Dock="Right"
                        Click="CloseButton_Click"
                        Background="Transparent"
                        Foreground="#999999"
                        BorderThickness="0"
                        Padding="8,2"
                        FontSize="13"
                        Cursor="Hand"/>
                <TextBlock Text="Create Slideshow"
                           Foreground="#4A90D9"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="#2A2A2A"
                BorderBrush="#444444"
                BorderThickness="0,1,0,0"
                Padding="16,6">
            <TextBlock x:Name="StatusText"
                       Text="Ready."
                       Foreground="#999999"
                       FontSize="12"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Main content -->
        <Grid Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Filters -->
            <Border Grid.Column="0"
                    Background="#252525"
                    BorderBrush="#444444"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Padding="16">
                    <StackPanel>

                        <TextBlock Text="Filters"
                                   Foreground="#4A90D9"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16"/>

                        <!-- YEAR -->
                        <TextBlock Text="Year"
                                   Foreground="#999999"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>
                        <ItemsControl x:Name="YearList"
                                      Margin="0,0,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Year}"
                                              Foreground="#F0F0F0"
                                              Margin="0,3"
                                              IsChecked="{Binding IsSelected}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- EVENT -->
                        <TextBlock Text="Event"
                                   Foreground="#999999"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>
                        <ItemsControl x:Name="EventList"
                                      Margin="0,0,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding EventName}"
                                              Foreground="#F0F0F0"
                                              Margin="0,3"
                                              IsChecked="{Binding IsSelected}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- PERSON -->
                        <TextBlock Text="Person"
                                   Foreground="#999999"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>
                        <ItemsControl x:Name="PersonList"
                                      Margin="0,0,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayName}"
                                              Foreground="#F0F0F0"
                                              Margin="0,3"
                                              IsChecked="{Binding IsSelected}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- TAG -->
                        <TextBlock Text="Tag"
                                   Foreground="#999999"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>
                        <ItemsControl x:Name="TagList"
                                      Margin="0,0,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding TagName}"
                                              Foreground="#F0F0F0"
                                              Margin="0,3"
                                              IsChecked="{Binding IsSelected}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- RIGHT: Configuration -->
            <StackPanel Grid.Column="1"
                        Margin="24"
                        VerticalAlignment="Top">

                <TextBlock Text="Configuration"
                           Foreground="#4A90D9"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,0,0,20"/>

                <!-- Name -->
                <TextBlock Text="Slideshow name"
                           Foreground="#999999"
                           FontSize="11"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="SlideshowNameBox"
                         Background="#333333"
                         Foreground="#F0F0F0"
                         BorderBrush="#444444"
                         BorderThickness="1"
                         Padding="8,6"
                         FontSize="13"
                         Margin="0,0,0,20"/>

                <!-- Directory -->
                <TextBlock Text="Target directory"
                           Foreground="#999999"
                           FontSize="11"
                           Margin="0,0,0,6"/>
                <DockPanel Margin="0,0,0,20">
                    <Button Content="Browse"
                            DockPanel.Dock="Right"
                            Click="BrowseDirectory_Click"
                            Background="#4A90D9"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="12,6"
                            FontSize="12"
                            Cursor="Hand"
                            Margin="8,0,0,0"/>
                    <TextBox x:Name="DirectoryBox"
                             Background="#333333"
                             Foreground="#F0F0F0"
                             BorderBrush="#444444"
                             BorderThickness="1"
                             Padding="8,6"
                             FontSize="13"
                             IsReadOnly="True"/>
                </DockPanel>

                <!-- Orientation -->
                <TextBlock Text="Orientation"
                           Foreground="#999999"
                           FontSize="11"
                           Margin="0,0,0,6"/>
                <StackPanel Margin="0,0,0,20">
                    <RadioButton x:Name="OrientationAuto"
                                 Content="Auto (based on image)"
                                 Foreground="#F0F0F0"
                                 IsChecked="True"
                                 Margin="0,3"/>
                    <RadioButton x:Name="OrientationLandscape"
                                 Content="Landscape (1920 x 1200)"
                                 Foreground="#F0F0F0"
                                 Margin="0,3"/>
                    <RadioButton x:Name="OrientationPortrait"
                                 Content="Portrait (1200 x 1920)"
                                 Foreground="#F0F0F0"
                                 Margin="0,3"/>
                </StackPanel>

                <!-- Resolution -->
                <TextBlock Text="Resolution"
                           Foreground="#999999"
                           FontSize="11"
                           Margin="0,0,0,6"/>
                <StackPanel Margin="0,0,0,32">
                    <RadioButton x:Name="Resolution1920"
                                 Content="1920 / 1200"
                                 Foreground="#F0F0F0"
                                 IsChecked="True"
                                 Margin="0,3"/>
                    
                </StackPanel>

                <!-- Create button -->
                <Button x:Name="CreateButton"
                        Content="Create Slideshow"
                        Click="CreateSlideshow_Click"
                        Background="#4A90D9"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="14,10"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        HorizontalAlignment="Left"/>

            </StackPanel>
        </Grid>
    </DockPanel>
</Window>