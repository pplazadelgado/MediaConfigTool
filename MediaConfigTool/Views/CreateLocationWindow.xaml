<Window x:Class="MediaConfigTool.Views.CreateLocationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Location"
        Height="280" Width="380"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border Background="#2A2A2A"
            BorderBrush="#444444"
            BorderThickness="1"
            CornerRadius="8">
        <StackPanel Margin="24">

            <!-- Header -->
            <TextBlock x:Name="HeaderText"
                       Text="Create Location"
                       Foreground="#4A90D9"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Margin="0,0,0,20"/>

            <!-- Name -->
            <TextBlock Text="Name *"
                       Foreground="#999999"
                       FontSize="11"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="NameBox"
                     Background="#333333"
                     Foreground="#F0F0F0"
                     BorderBrush="#444444"
                     BorderThickness="1"
                     Padding="8,6"
                     FontSize="13"
                     Margin="0,0,0,16"/>

            <!-- Location Type -->
            <TextBlock Text="Type *"
                       Foreground="#999999"
                       FontSize="11"
                       Margin="0,0,0,4"/>
            <ComboBox x:Name="TypeBox"
          FontSize="13"
          Height="32"
          Margin="0,0,0,20">
                <ComboBox.Resources>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#F0F0F0"/>
                        <Setter Property="Background" Value="#333333"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#444444"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#4A90D9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ComboBox.Resources>
                <ComboBox.Template>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="#333333"
                        BorderBrush="#444444"
                        BorderThickness="1"
                        CornerRadius="4">
                                <DockPanel>
                                    <ToggleButton DockPanel.Dock="Right"
                                      Width="24"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      IsChecked="{Binding Path=IsDropDownOpen,
                                                  RelativeSource={RelativeSource TemplatedParent},
                                                  Mode=TwoWay}"
                                      Focusable="False">
                                        <TextBlock Text="▾"
                                       Foreground="#999999"
                                       FontSize="11"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                                    </ToggleButton>
                                    <ContentPresenter Margin="8,0,0,0"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          TextElement.Foreground="#F0F0F0"/>
                                </DockPanel>
                            </Border>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                       AllowsTransparency="True"
                       Focusable="False"
                       PopupAnimation="Slide"
                       Placement="Bottom">
                                <Border Background="#333333"
                            BorderBrush="#444444"
                            BorderThickness="1"
                            CornerRadius="4"
                            MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </ComboBox.Template>
                <ComboBoxItem Content="world_region"/>
                <ComboBoxItem Content="country"/>
                <ComboBoxItem Content="state_region"/>
                <ComboBoxItem Content="city"/>
                <ComboBoxItem Content="poi"/>
                <ComboBoxItem Content="custom_place"/>
            </ComboBox>

            <!-- Buttons -->
            <DockPanel>
                <Button Content="Cancel"
                        DockPanel.Dock="Left"
                        Click="Cancel_Click"
                        Background="#444444"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="14,7"
                        FontSize="13"
                        Cursor="Hand"
                        Width="100">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="Save"
                        DockPanel.Dock="Right"
                        HorizontalAlignment="Right"
                        Click="Save_Click"
                        Background="#4A90D9"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="14,7"
                        FontSize="13"
                        Cursor="Hand"
                        Width="100">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </DockPanel>

        </StackPanel>
    </Border>
</Window>