<Window x:Class="MediaConfigTool.Views.CreateTagCategoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Tag Category"
        Height="220" Width="360"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border Background="#2A2A2A"
            BorderBrush="#444444"
            BorderThickness="1"
            CornerRadius="8">
        <StackPanel Margin="24">

            <TextBlock Text="Create Tag Category"
                       Foreground="#4A90D9"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Name *"
                       Foreground="#999999"
                       FontSize="11"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="NameBox"
                     Background="#333333"
                     Foreground="#F0F0F0"
                     BorderBrush="#444444"
                     BorderThickness="1"
                     Padding="8,6"
                     FontSize="13"
                     Margin="0,0,0,20"/>

            <DockPanel>
                <Button Content="Cancel"
                        DockPanel.Dock="Left"
                        Click="Cancel_Click"
                        Background="#444444"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="14,7"
                        FontSize="13"
                        Cursor="Hand"
                        Width="100">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Save"
                        DockPanel.Dock="Right"
                        HorizontalAlignment="Right"
                        Click="Save_Click"
                        Background="#4A90D9"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="14,7"
                        FontSize="13"
                        Cursor="Hand"
                        Width="100">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </DockPanel>

        </StackPanel>
    </Border>
</Window>
