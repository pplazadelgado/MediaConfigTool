<Window x:Class="MediaConfigTool.Views.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Render Preview"
        Width="1200" Height="780"
        Background="#1E1E1E"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <DockPanel Background="#1E1E1E">

        <!-- Top bar -->
        <Border DockPanel.Dock="Top"
                Background="#2A2A2A"
                BorderBrush="#444444"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <DockPanel>
                <Button Content="✕"
                        DockPanel.Dock="Right"
                        Click="CloseButton_Click"
                        Background="Transparent"
                        Foreground="#999999"
                        BorderThickness="0"
                        Padding="8,2"
                        FontSize="13"
                        Cursor="Hand"/>
                <Button Content="Save as PNG"
                        DockPanel.Dock="Right"
                        Click="SaveButton_Click"
                        Background="#4A90D9"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="14,7"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Margin="0,0,8,0"/>
                <TextBlock Text="Render Preview"
                           Foreground="#4A90D9"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Canvas de preview — escala el render 1200x1920 al espacio disponible -->
        <Viewbox Stretch="Uniform" >
            <Grid x:Name="RenderCanvas"
                          Width="1920" Height="1200"
                          Background="#0D1B2A"
                          HorizontalAlignment="Stretch"> 

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1520"/>
                            <ColumnDefinition Width="400"/>
                        </Grid.ColumnDefinitions>

                        <!-- MAIN IMAGE -->
                        <Border Grid.Column="0" Margin="20" Background="Black"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch">
                            <Image x:Name="MainImage"
                                 Stretch="UniformToFill"/>
                        </Border>

                        <!-- RIGHT PANEL -->
                        <Grid Grid.Column="1" Margin="20,20,20,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="560"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- MAP -->
                            <Border Grid.Row="0"
                                    Background="#1A2A3A"
                                    CornerRadius="12"
                                    Margin="0,0,0,20">      
                                <Image x:Name="MapImage"
                                    Stretch="UniformToFill"/>
                            </Border>

                            <!-- METADATA GRID 2x2 + full width bottom -->
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- DATE -->
                                <Border Grid.Row="0" Grid.Column="0"
                                    Background="#111C28"
                                    CornerRadius="12"
                                    Margin="0,0,10,10"> 
                                    <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Image Source="/Views/calendar.png"
                                   Width="150"
                                   Height="150"/>    
                                <TextBlock x:Name="DateText"
                                           Foreground="White"
                                           FontFamily="Georgia"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Margin="8,8,8,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- EVENT -->
                                <Border Grid.Row="0" Grid.Column="1"
                                    Background="#111C28"
                                    CornerRadius="12"
                                    Margin="10,0,0,10">
                                    <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Image Source="/Views/event.png"
                                    Width="150"
                                    Height="150"/>  
                                <TextBlock x:Name="EventText"
                                           Foreground="White"
                                           FontFamily="Georgia"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Margin="8,8,8,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- PERSONS -->
                                <Border Grid.Row="1" Grid.Column="0"
                                    Background="#111C28"
                                    CornerRadius="12"
                                    Margin="0,0,10,0">
                                    <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Image Source="/Views/person.png"
                                    Width="150"
                                    Height="150"/>  
                                <TextBlock x:Name="PersonText"
                                           Foreground="White"
                                           FontFamily="Georgia"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Margin="8,8,8,0"/>   
                                    </StackPanel>
                                </Border>

                                <!-- TAGS -->
                        <Border Grid.Row="1" Grid.Column="1"
                                    Background="#111C28"
                                    CornerRadius="12"
                                    Margin="10,0,0,0">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Image Source="/Views/calendar.png"
                                    Width="150"
                                    Height="150"/>  
                                <TextBlock x:Name="TagText"
                                           Foreground="White"
                                           FontFamily="Georgia"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Margin="8,8,8,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                        </Grid>

                    </Grid>
        </Viewbox>

    </DockPanel>
</Window>
