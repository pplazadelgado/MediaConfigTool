<Window x:Class="MediaConfigTool.Views.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Render Preview"
        Width="700" Height="820"
        Background="#1E1E1E"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <DockPanel Background="#1E1E1E">

        <!-- Top bar -->
        <Border DockPanel.Dock="Top"
                Background="#2A2A2A"
                BorderBrush="#444444"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <DockPanel>
                <Button Content="✕"
                        DockPanel.Dock="Right"
                        Click="CloseButton_Click"
                        Background="Transparent"
                        Foreground="#999999"
                        BorderThickness="0"
                        Padding="8,2"
                        FontSize="13"
                        Cursor="Hand"/>
                <Button Content="Save as PNG"
                        DockPanel.Dock="Right"
                        Click="SaveButton_Click"
                        Background="#4A90D9"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="14,7"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Margin="0,0,8,0"/>
                <TextBlock Text="Render Preview"
                           Foreground="#4A90D9"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Canvas de preview — escala el render 1200x1920 al 50% -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#1E1E1E">
            <Border Margin="16" HorizontalAlignment="Center">
                <Viewbox Width="600" Height="960">
                    <Grid x:Name="RenderCanvas"
                          Width="1200" Height="1920"
                          Background="#0D1B2A">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="780"/>
                            <ColumnDefinition Width="420"/>
                        </Grid.ColumnDefinitions>

                        <!-- MAIN IMAGE -->
                        <Border Grid.Column="0" Margin="20" Background="Black">
                            <Image x:Name="MainImage"
                                   Stretch="UniformToFill"/>
                        </Border>

                        <!-- RIGHT PANEL -->
                        <Grid Grid.Column="1" Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="800"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- MAP -->
                            <Border Grid.Row="0" Background="#1A2A3A" Margin="0,0,0,20">
                                <Image x:Name="MapImage"
                                       Stretch="Uniform"/>
                            </Border>

                            <!-- METADATA -->
                            <StackPanel Grid.Row="1" Orientation="Vertical">

                                <StackPanel Orientation="Horizontal" Margin="0,10">
                                    <TextBlock Text="📅"
                                               FontSize="40"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="DateText"
                                               Foreground="White"
                                               FontFamily="Georgia"
                                               FontSize="32"
                                               Margin="15,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,10">
                                    <TextBlock Text="📍"
                                               FontSize="40"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="LocationText"
                                               Foreground="White"
                                               FontFamily="Georgia"
                                               FontSize="32"
                                               Margin="15,0,0,0"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,10">
                                    <TextBlock Text="📅"
                                               FontSize="40"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="EventText"
                                               Foreground="White"
                                               FontFamily="Georgia"
                                               FontSize="32"
                                               Margin="15,0,0,0"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,10">
                                    <TextBlock Text="👤"
                                               FontSize="40"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="PersonText"
                                               Foreground="White"
                                               FontFamily="Georgia"
                                               FontSize="32"
                                               Margin="15,0,0,0"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,10">
                                    <TextBlock Text="🏷️"
                                               FontSize="40"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TagText"
                                               Foreground="White"
                                               FontFamily="Georgia"
                                               FontSize="32"
                                               Margin="15,0,0,0"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                            </StackPanel>
                        </Grid>

                    </Grid>
                </Viewbox>
            </Border>
        </ScrollViewer>

    </DockPanel>
</Window>
