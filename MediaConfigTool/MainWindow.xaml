<Window x:Class="MediaConfigTool.MainWindow"
        Icon="/Narrin.ico"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MediaConfigTool.ViewModels"
        Title="Narrim" Height="700" Width="1100"
        Background="#1E1E1E"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">



    <Window.Resources>

        <SolidColorBrush x:Key="BackgroundDark"  Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BackgroundPanel" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="BackgroundCard"  Color="#333333"/>
        <SolidColorBrush x:Key="AccentColor"     Color="#4A90D9"/>
        <SolidColorBrush x:Key="RenderAccentColor" Color="#F2D7A4"/>
        <SolidColorBrush x:Key="TextPrimary"     Color="#F0F0F0"/>
        <SolidColorBrush x:Key="TextSecondary"   Color="#999999"/>
        <SolidColorBrush x:Key="BorderColor"     Color="#444444"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#4A90D9"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5BA0E9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3A80C9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background"      Value="#333333"/>
            <Setter Property="Foreground"      Value="#F0F0F0"/>
            <Setter Property="BorderBrush"     Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                                <DockPanel>
                                    <ToggleButton DockPanel.Dock="Right"
                                          Width="24"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{Binding Path=IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False">
                                        <TextBlock Text="▾"
                                           Foreground="#999999"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                    </ToggleButton>
                                    <ContentPresenter Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              TextElement.Foreground="#F0F0F0"/>
                                </DockPanel>
                            </Border>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Slide"
                           Placement="Bottom">
                                <Border Background="#333333"
                                BorderBrush="#444444"
                                BorderThickness="1"
                                CornerRadius="4"
                                MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#F0F0F0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding"    Value="10,6"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#444444"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#4A90D9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThumbnailCard" TargetType="Border">
            <Setter Property="Background"      Value="#2A2A2A"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="BorderBrush"     Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin"          Value="6"/>
        </Style>

        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Width"      Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#555555"
                                                        CornerRadius="3"
                                                        Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThinScrollBarTree" TargetType="ScrollBar">
            <Setter Property="Width"      Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#555555"
                                                        CornerRadius="3"
                                                        Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width"  Value="Auto"/>
                    <Setter Property="Height" Value="6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TreeScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Column="0" Grid.Row="0"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1" Grid.Row="0"
                                       Style="{StaticResource ThinScrollBarTree}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       Orientation="Horizontal"
                                       Grid.Column="0" Grid.Row="1"
                                       Style="{StaticResource ThinScrollBarTree}"
                                       Value="{TemplateBinding HorizontalOffset}"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                            <Border Grid.Column="1" Grid.Row="1" Background="#252525"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkExpander" TargetType="Expander">
            <Setter Property="Foreground" Value="#4A90D9"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <!-- Header -->
                            <ToggleButton IsChecked="{Binding IsExpanded,
                                          RelativeSource={RelativeSource TemplatedParent},
                                          Mode=TwoWay}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Cursor="Hand"
                                          Padding="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" Padding="0,4">
                                            <DockPanel>
                                                <TextBlock x:Name="Arrow"
                                                           Text="▸"
                                                           Foreground="#4A90D9"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,6,0"/>
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="Text" Value="▾"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter ContentSource="Header"/>
                            </ToggleButton>
                            <!-- Content -->
                            <ContentPresenter x:Name="Body" Visibility="Collapsed"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="Body" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <DockPanel Background="#1E1E1E">

        <!-- Top bar -->
        <Border DockPanel.Dock="Top"
                Background="#2A2A2A"
                BorderBrush="#444444"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <DockPanel>

                <!-- Botón cerrar alineado a la derecha -->
                <Button Content="✕"
                        DockPanel.Dock="Right"
                        Click="CloseButton_Click"
                        Style="{StaticResource PrimaryButton}"
                        Background="Transparent"
                        Foreground="#999999"
                        Padding="8,2"
                        FontSize="13"/>

                <TextBlock Text="Narrin"
                           Foreground="#4A90D9"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,24,0"/>

                <TextBlock Text="Tenant"
                           Foreground="#999999"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <!-- ComboBox con placeholder -->
                <Grid Margin="0,0,16,0">
                    <ComboBox Width="220"
                              Style="{StaticResource DarkComboBox}"
                              ItemsSource="{Binding Tenants}"
                              SelectedItem="{Binding SelectedTenant}"
                              DisplayMemberPath="TenantName"
                              IsEnabled="{Binding TenantsLoaded}"/>
                    <TextBlock Text="Select tenant..."
                               Foreground="#666666"
                               FontSize="13"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTenant}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Button Content="Browse Folder"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding BrowseFolderCommand}"/>
                <Button Content="Import to Database"
        Style="{StaticResource PrimaryButton}"
        Command="{Binding ImportCommand}"
        Margin="8,0,0,0"/>

                <Button Content="Cancel"
                    Background="#C0392B"
                    Command="{Binding CancelImportCommand}"
                    Margin="4,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsImporting}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock Text="{Binding SelectedFolder}"
                           Foreground="#999999"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
        Background="#2A2A2A"
        BorderBrush="#444444"
        BorderThickness="0,1,0,0"
        Padding="16,6">
            <DockPanel>

                <!-- Spinner visible solo durante importación -->
                <TextBlock DockPanel.Dock="Left"
                   Text="⟳"
                   Foreground="#4A90D9"
                   FontSize="14"
                   Margin="0,0,8,0"
                   VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsImporting}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Icono de advertencia -->
                <TextBlock DockPanel.Dock="Left"
                   Text="⚠"
                   Foreground="#F0C040"
                   FontSize="13"
                   Margin="0,0,6,0"
                   VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusIsWarning}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Mensaje de estado -->
                <TextBlock Text="{Binding StatusMessage}"
                   FontSize="12"
                   VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#999999"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusIsWarning}" Value="True">
                                    <Setter Property="Foreground" Value="#F0C040"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsImporting}" Value="True">
                                    <Setter Property="Foreground" Value="#4A90D9"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

            </DockPanel>
        </Border>

        <!-- Contenido principal -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding FolderPanelWidth}"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Panel lateral de carpetas -->
            <Border Grid.Column="0"
                Background="#252525"
                BorderBrush="#444444"
                BorderThickness="0,0,1,0"
                Visibility="{Binding FolderPanelVisibility}">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                    Background="#2A2A2A"
                    Padding="12,10">
                        <DockPanel>
                            <TextBlock Text="Select Folder"
                           Foreground="#F0F0F0"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                            <Button Content="✕"
                        DockPanel.Dock="Right"
                        Command="{Binding CloseFolderPanelCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Background="Transparent"
                        Foreground="#999999"
                        Padding="6,2"
                        FontSize="12"/>
                        </DockPanel>
                    </Border>

                    <ScrollViewer Style="{StaticResource TreeScrollViewer}"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <TreeView Background="Transparent"
                      BorderThickness="0"
                      Foreground="#F0F0F0"
                      ItemsSource="{Binding RootFolders}"
                      Padding="4"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                      PreviewMouseWheel="FolderTree_PreviewMouseWheel">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="Foreground"                Value="#CCCCCC"/>
                                    <Setter Property="Background"                Value="Transparent"/>
                                    <Setter Property="Padding"                   Value="4,3"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    <EventSetter Event="Expanded" Handler="FolderTree_Expanded"/>
                                    <EventSetter Event="Selected" Handler="FolderTree_Selected"/>
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding SubFolders}">
                                    <TextBlock Text="{Binding Name}" FontSize="12"/>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </ScrollViewer>

                </DockPanel>
            </Border>
            <!-- Panel derecho de detalles -->
            <Border Grid.Column="2"
                    Background="#252525"
                    BorderBrush="#444444"
                    BorderThickness="1,0,0,0"
                    Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBar}"/>
                    </ScrollViewer.Resources>
                    <StackPanel>

                        <TextBlock Text="Selection"
                   Foreground="#4A90D9"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

                        <!-- Sin selección -->
                        <TextBlock Text="No image selected."
                   Foreground="#666666"
                   FontSize="12"
                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSelection}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Selección única -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSingleSelection}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Text="File"
                       Foreground="#666666"
                       FontSize="10"
                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SelectedFile.FileName}"
                       Foreground="#F0F0F0"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

                            <TextBlock Text="Relative path"
                       Foreground="#666666"
                       FontSize="10"
                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SelectedFile.RelativePath}"
                       Foreground="#F0F0F0"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

                            <TextBlock Text="Capture date"
                       Foreground="#666666"
                       FontSize="10"
                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SelectedFile.CaptureTimestamp, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                       Foreground="#F0F0F0"
                       FontSize="12"
                       Margin="0,0,0,12"/>
                        </StackPanel>


                        <!-- Selección múltiple -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMultiSelection}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Text="{Binding SelectedCount, StringFormat={}{0} images selected}"
                           Foreground="#F0F0F0"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                            <TextBlock Text="Imported"
                               Foreground="#666666"
                               FontSize="10"
                               Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SelectedImportedCount, StringFormat={}{0} images}"
                               Foreground="#27AE60"
                               FontSize="12"
                               Margin="0,0,0,12"/>

                            <TextBlock Text="Not imported"
                                   Foreground="#666666"
                                   FontSize="10"
                                   Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SelectedNotImportedCount, StringFormat={}{0} images}"
                                   Foreground="#E67E22"
                                   FontSize="12"
                                   Margin="0,0,0,12"/>

                            <TextBlock Text="Only imported images can receive metadata."
                           Foreground="#666666"
                           FontSize="11"
                           TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Separator -->
                        <Border Height="1"
                            Background="#444444"
                            Margin="0,16,0,16"/>

                        <!-- Locations -->
                        <Expander Style="{StaticResource DarkExpander}" IsExpanded="True">
                            <Expander.Header>
                                <TextBlock Text="📍 Locations"
                                           Foreground="#4A90D9"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                            </Expander.Header>
                            <StackPanel Margin="0,8,0,0">
                                <ListBox ItemsSource="{Binding Locations}"
                                         SelectedItem="{Binding SelectedLocation}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         MaxHeight="200">
                                    <ListBox.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBar}"/>
                                    </ListBox.Resources>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="8,5"/>
                                            <Setter Property="Foreground" Value="#CCCCCC"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="4"
                                                                Padding="{TemplateBinding Padding}">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding LocationName}" FontSize="12" Foreground="#F0F0F0"/>
                                                                <TextBlock Text="{Binding LocationType}" FontSize="10" Foreground="#666666"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#333333"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter Property="Background" Value="#4A90D9"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                                <Button Content="Assign Location"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding AssignLocationCommand}"
                                        Margin="0,8,0,0"/>
                            </StackPanel>
                        </Expander>

                        <!-- Persons -->
                        <Expander Style="{StaticResource DarkExpander}">
                            <Expander.Header>
                                <TextBlock Text="👤 Persons"
                                           Foreground="#4A90D9"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                            </Expander.Header>
                            <StackPanel Margin="0,8,0,0">
                                <ListBox ItemsSource="{Binding Persons}"
                                         SelectedItem="{Binding SelectedPerson}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         MaxHeight="200">
                                    <ListBox.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBar}"/>
                                    </ListBox.Resources>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="8,5"/>
                                            <Setter Property="Foreground" Value="#CCCCCC"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="4"
                                                                Padding="{TemplateBinding Padding}">
                                                            <TextBlock Text="{Binding DisplayName}" FontSize="12"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#333333"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter Property="Background" Value="#4A90D9"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                                <Button Content="Assign Person"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding AssignPersonCommand}"
                                        Margin="0,8,0,0"/>
                            </StackPanel>
                        </Expander>

                        <!-- Events -->
                        <Expander Style="{StaticResource DarkExpander}">
                            <Expander.Header>
                                <TextBlock Text="📅 Events"
                                           Foreground="#4A90D9"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                            </Expander.Header>
                            <StackPanel Margin="0,8,0,0">
                                <ListBox ItemsSource="{Binding Events}"
                                         SelectedItem="{Binding SelectedEvent}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         MaxHeight="200">
                                    <ListBox.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBar}"/>
                                    </ListBox.Resources>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="8,5"/>
                                            <Setter Property="Foreground" Value="#CCCCCC"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="4"
                                                                Padding="{TemplateBinding Padding}">
                                                            <TextBlock Text="{Binding EventName}" FontSize="12"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#333333"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter Property="Background" Value="#4A90D9"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                                <Button Content="Assign Event"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding AssignEventCommand}"
                                        Margin="0,8,0,0"/>
                            </StackPanel>
                        </Expander>

                        <!-- Tags -->
                        <Expander Style="{StaticResource DarkExpander}">
                            <Expander.Header>
                                <TextBlock Text="🏷️ Tags"
                                           Foreground="#4A90D9"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                            </Expander.Header>
                            <StackPanel Margin="0,8,0,0">
                                <ListBox ItemsSource="{Binding Tags}"
                                         SelectedItem="{Binding SelectedTag}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         MaxHeight="200">
                                    <ListBox.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBar}"/>
                                    </ListBox.Resources>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="8,5"/>
                                            <Setter Property="Foreground" Value="#CCCCCC"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="4"
                                                                Padding="{TemplateBinding Padding}">
                                                            <TextBlock Text="{Binding TagName}" FontSize="12"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#333333"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter Property="Background" Value="#4A90D9"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                                <Button Content="Assign Tag"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding AssignTagCommand}"
                                        Margin="0,8,0,0"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Galería -->
            <ListView x:Name="MediaGallery"
                  Grid.Column="1"
                  ItemsSource="{Binding MediaFiles}"
                  SelectionMode="Extended"
                  SelectionChanged="MediaGallery_SelectionChanged"
                  Background="Transparent"
                  BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  Padding="10">
                <ListView.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBar}"/>
                </ListView.Resources>
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background"      Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding"         Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="SelectionBorder"
                            BorderBrush="Transparent"
                            BorderThickness="3"
                            CornerRadius="8">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="SelectionBorder"
                                    Property="BorderBrush"
                                    Value="#4A90D9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ThumbnailCard}" Width="170">
                            <Grid>
                                <StackPanel>
                                    <Border CornerRadius="5,5,0,0"
                                        ClipToBounds="True"
                                        Width="170" Height="120"
                                        Background="#1A1A1A">
                                                                    <Image Source="{Binding Thumbnail}"
                                           Width="170" Height="120"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>  
                                    </Border>
                                    <TextBlock Text="{Binding FileName}"
                       Foreground="#CCCCCC"
                       FontSize="10"
                       Margin="8,5,8,6"
                       TextTrimming="CharacterEllipsis"
                       HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- Indicador de importado -->
                                <Border HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="#27AE60"
                CornerRadius="0,5,0,5"
                Padding="5,3"
                Margin="0,1,1,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsImported}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="✓"
                       Foreground="White"
                       FontSize="10"
                       FontWeight="Bold"/>
                                </Border>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </Grid>
    </DockPanel>
</Window>