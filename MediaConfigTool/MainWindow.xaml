<Window x:Class="MediaConfigTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MediaConfigTool.ViewModels"
        Title="MediaConfigTool" Height="700" Width="1100"
        Background="#1E1E1E"
        WindowStyle="None"
        AllowsTransparency="True"
        Loaded="Window_Loaded">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>

        <SolidColorBrush x:Key="BackgroundDark"  Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BackgroundPanel" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="BackgroundCard"  Color="#333333"/>
        <SolidColorBrush x:Key="AccentColor"     Color="#4A90D9"/>
        <SolidColorBrush x:Key="TextPrimary"     Color="#F0F0F0"/>
        <SolidColorBrush x:Key="TextSecondary"   Color="#999999"/>
        <SolidColorBrush x:Key="BorderColor"     Color="#444444"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#4A90D9"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5BA0E9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3A80C9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background"      Value="#333333"/>
            <Setter Property="Foreground"      Value="#F0F0F0"/>
            <Setter Property="BorderBrush"     Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                                <DockPanel>
                                    <ToggleButton DockPanel.Dock="Right"
                                          Width="24"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{Binding Path=IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False">
                                        <TextBlock Text="▾"
                                           Foreground="#999999"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                    </ToggleButton>
                                    <ContentPresenter Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              TextElement.Foreground="#F0F0F0"/>
                                </DockPanel>
                            </Border>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Slide"
                           Placement="Bottom">
                                <Border Background="#333333"
                                BorderBrush="#444444"
                                BorderThickness="1"
                                CornerRadius="4"
                                MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#F0F0F0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding"    Value="10,6"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#444444"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#4A90D9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ThumbnailCard" TargetType="Border">
            <Setter Property="Background"      Value="#2A2A2A"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="BorderBrush"     Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin"          Value="6"/>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width"      Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#555555"
                                                        CornerRadius="3"
                                                        Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <DockPanel Background="#1E1E1E">

        <!-- Top bar -->
        <Border DockPanel.Dock="Top"
                Background="#2A2A2A"
                BorderBrush="#444444"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <DockPanel>

                <!-- Botón cerrar alineado a la derecha -->
                <Button Content="✕"
                        DockPanel.Dock="Right"
                        Click="CloseButton_Click"
                        Style="{StaticResource PrimaryButton}"
                        Background="Transparent"
                        Foreground="#999999"
                        Padding="8,2"
                        FontSize="13"/>

                <TextBlock Text="MediaConfigTool"
                           Foreground="#4A90D9"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,24,0"/>

                <TextBlock Text="Tenant"
                           Foreground="#999999"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <!-- ComboBox con placeholder -->
                <Grid Margin="0,0,16,0">
                    <ComboBox Width="220"
                              Style="{StaticResource DarkComboBox}"
                              ItemsSource="{Binding Tenants}"
                              SelectedItem="{Binding SelectedTenant}"
                              DisplayMemberPath="TenantName"
                              IsEnabled="{Binding TenantsLoaded}"/>
                    <TextBlock Text="Select tenant..."
                               Foreground="#666666"
                               FontSize="13"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTenant}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Button Content="Browse Folder"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding BrowseFolderCommand}"/>

                <TextBlock Text="{Binding SelectedFolder}"
                           Foreground="#999999"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="#2A2A2A"
                BorderBrush="#444444"
                BorderThickness="0,1,0,0"
                Padding="16,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠"
                           Foreground="#F0C040"
                           FontSize="13"
                           Margin="0,0,6,0"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusIsWarning}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#999999"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusIsWarning}" Value="True">
                                    <Setter Property="Foreground" Value="#F0C040"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Contenido principal -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding FolderPanelWidth}"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Panel lateral de carpetas -->
            <Border Grid.Column="0"
                    Background="#252525"
                    BorderBrush="#444444"
                    BorderThickness="0,0,1,0"
                    Visibility="{Binding FolderPanelVisibility}">
                <DockPanel>

                    <Border DockPanel.Dock="Top"
                            Background="#2A2A2A"
                            Padding="12,10">
                        <DockPanel>
                            <TextBlock Text="Select Folder"
                                       Foreground="#F0F0F0"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button Content="✕"
                                    DockPanel.Dock="Right"
                                    Command="{Binding CloseFolderPanelCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Background="Transparent"
                                    Foreground="#999999"
                                    Padding="6,2"
                                    FontSize="12"/>
                        </DockPanel>
                    </Border>

                    <TreeView Background="Transparent"
                              BorderThickness="0"
                              Foreground="#F0F0F0"
                              ItemsSource="{Binding RootFolders}"
                              Padding="4">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding"    Value="4,3"/>
                                <EventSetter Event="Expanded" Handler="FolderTree_Expanded"/>
                                <EventSetter Event="Selected" Handler="FolderTree_Selected"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding SubFolders}">
                                <TextBlock Text="{Binding Name}" FontSize="12"/>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                </DockPanel>
            </Border>

            <!-- Galería -->
            <ListView Grid.Column="1"
                      ItemsSource="{Binding MediaFiles}"
                      Background="Transparent"
                      BorderThickness="0"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      Padding="10">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background"      Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding"         Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ThumbnailCard}" Width="170">
                            <StackPanel>
                                <Border CornerRadius="5,5,0,0" ClipToBounds="True">
                                    <Image Source="{Binding Thumbnail}"
                                           Width="170" Height="120"
                                           Stretch="UniformToFill"/>
                                </Border>
                                <TextBlock Text="{Binding FileName}"
                                           Foreground="#CCCCCC"
                                           FontSize="10"
                                           Margin="8,5,8,6"
                                           TextTrimming="CharacterEllipsis"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </Grid>
    </DockPanel>
</Window>