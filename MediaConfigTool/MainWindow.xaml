<Window x:Class="MediaConfigTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MediaConfigTool.ViewModels"
        Title="MediaConfigTool" Height="700" Width="1100"
        Loaded="Window_Loaded">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <DockPanel Margin="16">

        <!-- Top bar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">

            <TextBlock Text="Tenant:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox Width="220"
                      ItemsSource="{Binding Tenants}"
                      SelectedItem="{Binding SelectedTenant}"
                      DisplayMemberPath="TenantName"
                      Margin="0,0,16,0"/>

            <Button Content="Browse Folder"
                    Command="{Binding BrowseFolderCommand}"
                    Padding="10,4"/>

            <TextBlock Text="{Binding SelectedFolder}"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Foreground="Gray"/>
        </StackPanel>

        <!-- Status bar -->
        <TextBlock DockPanel.Dock="Bottom"
                   Text="{Binding StatusMessage}"
                   Foreground="Gray"
                   Margin="0,8,0,0"/>

        <!-- Image grid -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding MediaFiles}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="6" Width="160">
                            <Image Source="{Binding Thumbnail}"
                               Width="160" Height="120"
                               Stretch="UniformToFill"/>        
                            <TextBlock Text="{Binding FileName}"
                               FontSize="10"
                               TextTrimming="CharacterEllipsis"
                               HorizontalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>